{
  "manifest_version": 3,
  "name": "Woi AI Collector",
  "version": "0.1.0",
  "description": "Highlight text and send it to Woi\u2019s Assistant AI for retrieval now and training later.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Woi AI Collector"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}